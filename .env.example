# Clawcoin Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env
#
# Tags:
#   [DEV]       — Only needed for local dev / Pi deployment workflow
#   [ONBOARD]   — Production users set this via Clawbot onboarding, not manually
#   [DEPLOY]    — Only needed when deploying contracts

# ─── Raspberry Pi — SSH deployment target [DEV] ───────────────────────────────
PI_HOST=                              # IP address or hostname
PI_USER=                              # SSH username
PI_PASSWORD=                          # SSH password (or use PI_SSH_KEY_PATH instead)
PI_SSH_KEY_PATH=                      # Path to SSH private key (alternative to password)
PI_DEPLOY_DIR=~/clawcoin              # Remote install directory

# ─── AI API Keys [ONBOARD] ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=                    # Claude API key (for OpenClaw agent)
OPENAI_API_KEY=                       # OpenAI key (if needed by plugins)

# ─── Blockchain RPC Endpoints [ONBOARD] ──────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org           # Base L2 mainnet
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org   # Base Sepolia testnet

# ─── Clawcoin Secrets [ONBOARD] ─────────────────────────────────────────────
CLAWCOIN_KEYSTORE_PASSWORD=           # Encrypts bot execution keypair (CRITICAL — never commit)

# ─── Token Configuration [ONBOARD] ──────────────────────────────────────────
# Operator sets these when creating their assistant
TOKEN_NAME=                           # ERC-20 token name (e.g., Clawcoin)
TOKEN_SYMBOL=                         # ERC-20 token symbol (e.g., CLAW)
TOKEN_SUPPLY=                         # Total supply in whole tokens (e.g., 1000000)
CLIFF_MONTHS=                         # Vesting cliff in months (e.g., 6)
VESTING_MONTHS=                       # Total vesting duration in months (e.g., 24)

# ─── Contract Deployment [DEPLOY] ───────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=                 # Private key for deploying contracts to Base
TREASURY_SAFE_ADDRESS=                # Safe smart account to receive 80% token supply
VESTING_BENEFICIARY=                  # Address that can claim vested 20% allocation

# ─── Testing [DEV] ──────────────────────────────────────────────────────────
HARDHAT_NODE_URL=http://127.0.0.1:8545
FORK_BASE=                            # Set to "1" to enable Base mainnet forking
